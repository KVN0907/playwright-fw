# Example configurations for different authentication types
# Copy the relevant section to your .env.{environment} file

# ====================================================================
# BROWSER SESSION AUTHENTICATION (Current Default)
# ====================================================================
# Uses browser login with username/password and maintains session cookies
AUTH_TYPE=browser_session
USERNAME=your_username
PASSWORD=your_password

# ====================================================================
# BEARER TOKEN AUTHENTICATION
# ====================================================================
# Use a pre-generated bearer token
# AUTH_TYPE=bearer_token
# AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ====================================================================
# JWT TOKEN AUTHENTICATION
# ====================================================================
# Authenticate with username/password to get JWT token
# AUTH_TYPE=jwt_token
# USERNAME=your_username
# PASSWORD=your_password
# LOGIN_ENDPOINT=/api/auth/login
# TOKEN_FIELD=access_token

# ====================================================================
# API KEY AUTHENTICATION
# ====================================================================
# Use API key in X-API-Key header
# AUTH_TYPE=api_key
# API_KEY=your_api_key_here

# ====================================================================
# BASIC AUTHENTICATION
# ====================================================================
# Use HTTP Basic Auth with username/password
# AUTH_TYPE=basic_auth
# USERNAME=your_username
# PASSWORD=your_password

# ====================================================================
# OAUTH2 AUTHENTICATION
# ====================================================================
# OAuth2 client credentials flow
# AUTH_TYPE=oauth2
# CLIENT_ID=your_client_id
# CLIENT_SECRET=your_client_secret
# TOKEN_ENDPOINT=/oauth/token

# ====================================================================
# CUSTOM HEADERS AUTHENTICATION
# ====================================================================
# Use custom headers for authentication
# AUTH_TYPE=custom_headers
# CUSTOM_HEADERS={"X-Auth-Token":"your_token","X-User-ID":"user123"}

# ====================================================================
# COMMON CONFIGURATION (All Types)
# ====================================================================
# Base URLs
APP_URL=https://your-app.com/
API_URL=https://your-app.com/api

# Optional: Custom endpoints
# LOGIN_ENDPOINT=/custom/login
# TOKEN_ENDPOINT=/custom/token
# REFRESH_ENDPOINT=/custom/refresh
# STORAGE_KEY=custom_auth_token
# TOKEN_FIELD=custom_token_field
