# Mobile Test Profile
# Mobile device testing configuration
# Usage: PROFILE=mobile npm run test:qa

# Test execution
TIMEOUT=45000
RETRIES=1
PARALLEL_THREAD=2
HEADLESS=false
SLOW_MO=100

# Reporting
VIDEO=retain-on-failure
SCREENSHOT=on
TRACE=retain-on-failure

# Mobile specific settings can be added here
# VIEWPORT_WIDTH=375
# VIEWPORT_HEIGHT=667
# DEVICE_SCALE_FACTOR=2
