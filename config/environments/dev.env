# Environment Setting
NODE_ENV=dev

# Base URL (default fallback)
APP_URL=https://eycompliancemanager-dev.ey.com/

# Development environment variables
DEV_APP_URL=https://eycompliancemanager-dev.ey.com/
DEV_API_URL=https://eycompliancemanager-dev.ey.com/api
DEV_USERNAME=superadmin
DEV_PASSWORD=superadmin
DEV_SSO_USERNAME=superadmin
DEV_SSO_PASSWORD=superadmin

# Authentication Configuration
AUTH_TYPE=browser_session
LOGIN_TYPE=keycloak
HAS_LANDING_PAGE=true

# Timeouts
PAGE_TIMEOUT=10000
VERIFY_TIMEOUT=15000

# Test Configuration
TIMEOUT=30000
RETRIES=1
PARALLEL_THREAD=4
HEADLESS=false
SLOW_MO=100
VIDEO=retain-on-failure
SCREENSHOT=only-on-failure
TRACE=retain-on-failure

# Browser Settings
BROWSER=chromium

# Reporting
REPORTER=playwright-enhanced-reporter
REPORT_OUTPUT_DIR=test-results/dev/enhanced-report
