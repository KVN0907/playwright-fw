# Development Environment Variables
NODE_ENV=dev
DEV_BASE_URL=https://saasifier-dev.ey.com/
DEV_API_URL=https://saasifier-dev.ey.com/api
DEV_SSO_USERNAME=your-dev-username
DEV_SSO_PASSWORD=your-dev-password

# Test Configuration
TIMEOUT=30000
RETRIES=1
PARALLEL_THREAD=4
HEADLESS=false
SLOW_MO=0
VIDEO=retain-on-failure
SCREENSHOT=only-on-failure
TRACE=retain-on-failure

# Browser Settings
BROWSER=chromium

# Reporting
ALLURE_RESULTS_DIR=test-results/allure-results
ALLURE_REPORT_DIR=test-results/allure-report
