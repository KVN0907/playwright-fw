# Environment Setting
NODE_ENV=dev

# Base URL (default fallback)
APP_URL=https://eycompliancemanager-dev.ey.com/

# Development environment variables
DEV_APP_URL=https://eycompliancemanager-dev.ey.com/
DEV_API_URL=https://eycompliancemanager-dev.ey.com/api
DEV_USERNAME=superadmin
DEV_PASSWORD=superadmin
DEV_SSO_USERNAME=superadmin
DEV_SSO_PASSWORD=superadmin

# Multi-User Credentials (Role-Based Testing)
# Super Admin - Full CRUD access
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=superadmin

# EY Admin - Full CRUD access
EY_ADMIN_USERNAME=eyadmin
EY_ADMIN_PASSWORD=PLACEHOLDER_PASSWORD

# Client Admin - Read only
CLIENT_ADMIN_USERNAME=clientadmin
CLIENT_ADMIN_PASSWORD=PLACEHOLDER_PASSWORD

# Viewer - Read only
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=PLACEHOLDER_PASSWORD

# Reviewer - Read only
REVIEWER_USERNAME=reviewer
REVIEWER_PASSWORD=PLACEHOLDER_PASSWORD

# Authentication Configuration
AUTH_TYPE=browser_session
LOGIN_TYPE=keycloak
HAS_LANDING_PAGE=true

# Timeouts
PAGE_TIMEOUT=10000
VERIFY_TIMEOUT=15000

# Test Configuration
TIMEOUT=30000
RETRIES=1
PARALLEL_THREAD=4
HEADLESS=false
SLOW_MO=100
VIDEO=retain-on-failure
SCREENSHOT=only-on-failure
TRACE=retain-on-failure

# Browser Settings
BROWSER=chromium

# Reporting
REPORTER=playwright-enhanced-reporter
REPORT_OUTPUT_DIR=test-results/dev/enhanced-report
