# Environment Setting
NODE_ENV=prod

# Base URL (default fallback)
APP_URL=https://infinity.ey.com/

# Production environment variables
PROD_APP_URL=https://infinity.ey.com/
PROD_API_URL=https://infinity.ey.com/api
PROD_USERNAME=prodadmin
PROD_PASSWORD=prodadmin
PROD_SSO_USERNAME=prodadmin
PROD_SSO_PASSWORD=prodadmin

# Authentication Configuration
AUTH_TYPE=browser_session
HAS_LANDING_PAGE=true

# Timeouts
PAGE_TIMEOUT=20000
VERIFY_TIMEOUT=25000

# Test Configuration
TIMEOUT=90000
RETRIES=2
PARALLEL_THREAD=2
HEADLESS=true
SLOW_MO=0
VIDEO=retain-on-failure
SCREENSHOT=only-on-failure
TRACE=retain-on-failure

# Browser Settings
BROWSER=chromium

# Reporting
REPORTER=playwright-enhanced-reporter
REPORT_OUTPUT_DIR=test-results/prod/enhanced-report
