# Environment Setting
NODE_ENV=staging

# Base URL (default fallback)
APP_URL=https://infinity-staging.ey.com/

# Staging environment variables
STAGING_APP_URL=https://infinity-staging.ey.com/
STAGING_API_URL=https://infinity-staging.ey.com/api
STAGING_USERNAME=admin
STAGING_PASSWORD=admin
STAGING_SSO_USERNAME=admin
STAGING_SSO_PASSWORD=admin

# Authentication Configuration
AUTH_TYPE=browser_session
HAS_LANDING_PAGE=true

# Timeouts
PAGE_TIMEOUT=15000
VERIFY_TIMEOUT=20000

# Test Configuration
TIMEOUT=60000
RETRIES=1
PARALLEL_THREAD=3
HEADLESS=true
SLOW_MO=0
VIDEO=retain-on-failure
SCREENSHOT=only-on-failure
TRACE=retain-on-failure

# Browser Settings
BROWSER=chromium

# Reporting
REPORTER=playwright-enhanced-reporter
REPORT_OUTPUT_DIR=test-results/staging/enhanced-report
