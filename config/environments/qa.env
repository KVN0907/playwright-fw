# Environment Setting
NODE_ENV=qa

# Base URL (default fallback)
APP_URL=https://eycompliancemanager-uat.ey.com/

# QA environment variables
QA_APP_URL=https://eycompliancemanager-uat.ey.com/
QA_API_URL=https://eycompliancemanager-uat.ey.com
QA_USERNAME=Keerthivasan.Rc@in.ey.com
QA_PASSWORD=superadmin
QA_SSO_USERNAME=Keerthivasan.Rc@in.ey.com
QA_SSO_PASSWORD=superadmin

# Multi-User Credentials (Role-Based Testing)
# EY Admin - Can create clients but not Super Admin level access
EY_ADMIN_USERNAME=sg8@in.ey.com
EY_ADMIN_PASSWORD=eyadmin

# Client Admin - Read only access
CLIENT_ADMIN_USERNAME=PLACEHOLDER_CLIENT_ADMIN_EMAIL
CLIENT_ADMIN_PASSWORD=PLACEHOLDER_PASSWORD

# Authentication Configuration
AUTH_TYPE=browser_session
LOGIN_TYPE=keycloak
HAS_LANDING_PAGE=true

# Timeouts
PAGE_TIMEOUT=10000
VERIFY_TIMEOUT=15000

# Test Configuration
TIMEOUT=45000
RETRIES=2
PARALLEL_THREAD=2
HEADLESS=true
SLOW_MO=0
VIDEO=retain-on-failure
SCREENSHOT=only-on-failure
TRACE=retain-on-failure

# Browser Settings
BROWSER=chromium

# Reporting
REPORTER=playwright-enhanced-reporter
REPORT_OUTPUT_DIR=test-results/qa/enhanced-report
