{
  "name": "playwrightfw",
  "version": "1.0.0",
  "description": "Infinity Automation.",
  "main": "index.js",
  "scripts": {
    "// Test Execution - Advanced Environment Management": "",
    "test": "npm run clean && playwright test",
    "test:env": "npm run test -- --headed",
    "test:dev": "cross-env NODE_ENV=dev npm run test",
    "test:qa": "cross-env NODE_ENV=qa npm run test:env",
    "test:staging": "cross-env NODE_ENV=staging npm run test",
    "test:prod": "cross-env NODE_ENV=prod npm run test",
    "// Test Categories & Filtering": "",
    "test:ui": "npm run test -- src/tests/ui --headed",
    "test:api": "npm run test -- src/tests/api",
    "test:api:sprint1": "npm run test -- src/tests/api/Sprint1",
    "test:api:sprint2": "npm run test -- src/tests/api/Sprint2",
    "test:api:e2e": "npm run test -- src/tests/api/e2e",
    "test:api:domains": "npm run test -- src/tests/api/domains",
    "test:smoke": "npm run test -- --grep '@smoke'",
    "test:regression": "npm run test -- --grep '@regression'",
    "test:e2e": "npm run test -- --grep '@e2e'",
    "test:debug": "npm run test -- --debug --workers=1",
    "// Browser & Performance Testing": "",
    "test:browsers": "npm run test -- --project=chromium --project=firefox --project=webkit",
    "test:chromium": "npm run test -- --project=chromium",
    "test:firefox": "npm run test -- --project=firefox",
    "test:webkit": "npm run test -- --project=webkit",
    "test:mobile": "npm run test -- --project=mobile-chrome",
    "test:parallel": "npm run test -- --workers=4",
    "test:cloud": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 pwc --pwc-debug=full --key 86CygT0blrunOUXm --project-id VKVIEo",
    "// Reporting & Analysis": "",
    "report": "playwright show-report",
    "trace": "playwright show-trace",
    "report:enhanced": "start test-results/qa/enhanced-report/index.html",
    "report:enhanced:dev": "start test-results/dev/enhanced-report/index.html",
    "report:enhanced:qa": "start test-results/qa/enhanced-report/index.html",
    "report:enhanced:staging": "start test-results/staging/enhanced-report/index.html",
    "report:enhanced:prod": "start test-results/prod/enhanced-report/index.html",
    "report:detailed": "start test-results/qa/test-results.json",
    "report:open": "explorer test-results",
    "// Code Quality & Maintenance": "",
    "lint": "eslint **/*.{ts,js} --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\" && npm run lint",
    "clean": "rimraf test-results playwright-report .nyc_output coverage",
    "setup": "npm run clean && playwright install",
    "// ADO Integration & Generation": "",
    "ado:generate": "ts-node src/lib/adoTestGeneration/cli.ts",
    "ado:test": "node src/lib/adoTestGeneration/test-connection.js",
    "ado:test-connection": "ts-node -e \"require('./src/lib/ADOHelper').testADOConnection({organization: process.env.ADO_ORGANIZATION, project: process.env.ADO_PROJECT, personalAccessToken: process.env.ADO_PAT}).then(r => console.log(r ? '✅ Connected' : '❌ Failed'))\"",
    "generate": "playwright codegen",
    "// MCP-Assisted Generation": "",
    "generate:from-mcp": "ts-node scripts/generate-tests-from-mcp.ts",
    "sprint:coverage": "ts-node scripts/sprint-test-coverage.ts",
    "// Hybrid Test Generation (Code + ADO)": "",
    "generate:hybrid": "ts-node src/lib/cli-generate-hybrid.ts",
    "generate:api": "ts-node src/lib/cli-generate-hybrid.ts --controllers",
    "generate:ui": "ts-node src/lib/cli-generate-hybrid.ts --components",
    "generate:all": "ts-node src/lib/cli-generate-hybrid.ts --controllers --components",
    "// Comprehensive Test Generation (Zero Manual Intervention)": "",
    "generate:comprehensive": "npx ts-node src/lib/cli-generate-comprehensive.ts",
    "generate:comprehensive:security": "npx ts-node src/lib/cli-generate-comprehensive.ts --service security",
    "// RAG-Enhanced Test Generation (AI-Powered)": "",
    "rag:index": "npx ts-node src/lib/rag/cli-rag-generate.ts --index",
    "rag:reindex": "npx ts-node src/lib/rag/cli-rag-generate.ts --reindex",
    "rag:generate": "npx ts-node src/lib/rag/cli-rag-generate.ts --generate",
    "rag:swagger": "npx ts-node src/lib/rag/cli-rag-generate.ts --generate --swagger",
    "rag:help": "npx ts-node src/lib/rag/cli-rag-generate.ts --help",
    "// UI Development Server": "",
    "ui:install": "cd ui && npm ci && cd client && npm ci && cd ../server && npm ci",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "ui:start": "cd ui && npm run start",
    "ui:setup": "npm run ui:install && npm run ui:build",
    "// Utility & Lifecycle": "",
    "pretest": "npm run clean",
    "postinstall": "playwright install",
    "dev": "npm run test:dev",
    "start": "npm run ui:start",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{js,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@cucumber/cucumber": "^12.4.0",
    "@currents/playwright": "^1.20.0",
    "@faker-js/faker": "^10.1.0",
    "@pact-foundation/pact": "^16.0.4",
    "@playwright/experimental-ct-react": "^1.57.0",
    "@playwright/test": "^1.57.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "moment": "^2.30.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.7.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@langchain/community": "^1.1.1",
    "@langchain/core": "^1.1.7",
    "@langchain/openai": "^1.2.0",
    "@playwright/mcp": "^0.0.53",
    "@types/cucumber-html-reporter": "^5.0.4",
    "@types/winston": "^2.4.4",
    "chromadb": "^3.1.8",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^17.2.3",
    "fs-extra": "^11.3.3",
    "langchain": "^1.2.2",
    "openai": "^6.15.0",
    "playwright-enhanced-reporter": "^2.2.0",
    "playwright-test-generator": "^1.0.3",
    "playwrightfw": "file:",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
