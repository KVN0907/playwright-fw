{
  "name": "playwrightfw",
  "version": "1.0.0",
  "description": "Infinity Automation.",
  "main": "index.js",
  "scripts": {
    "test:qa": "cross-env NODE_ENV=qa npx playwright test --headed",
    "test:dev:headless": "cross-env NODE_ENV=dev npx playwright test",
    "test:staging": "cross-env NODE_ENV=staging npx playwright test",
    "test:prod": "cross-env NODE_ENV=prod npx playwright test",
    "test:ui": "cross-env NODE_ENV=qa npx playwright test tests/uiTests/e2e --headed",
    "test:api": "cross-env NODE_ENV=qa npx playwright test tests/apiTests",
    "test:smoke": "cross-env NODE_ENV=qa npx playwright test --grep \"@smoke\"",
    "test:regression": "cross-env NODE_ENV=qa npx playwright test --grep \"@regression\"",
    "test:parallel": "cross-env NODE_ENV=qa npx playwright test --workers=4",
    "test:debug": "cross-env NODE_ENV=qa npx playwright test --debug",
    "test:headed": "cross-env NODE_ENV=qa npx playwright test --headed --workers=1",
    "test:chromium": "cross-env NODE_ENV=qa npx playwright test --project=chromium",
    "test:firefox": "cross-env NODE_ENV=qa npx playwright test --project=firefox",
    "test:webkit": "cross-env NODE_ENV=qa npx playwright test --project=webkit",
    "test:mobile": "cross-env NODE_ENV=qa npx playwright test --project=mobile-chrome",
    "test:currents": "cross-env NODE_TLS_REJECT_UNAUTHORIZED='0' npx pwc --pwc-debug=full --key 86CygT0blrunOUXm --project-id VKVIEo",
    "show:report": "npx playwright show-report",
    "show:trace": "npx playwright show-trace",
    "show:enhanced": "start test-results/reports/enhanced-report.html",
    "show:detailed": "start test-results/reports/detailed-report.json",
    "show:reports": "explorer test-results\\reports",
    "install:browsers": "npx playwright install",
    "generate:tests": "npx playwright codegen",
    "lint": "eslint tests/**/*.ts",
    "lint:fix": "eslint tests/**/*.ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "format:tests": "prettier --write \"tests/**/*.{ts,js}\"",
    "clean": "rimraf test-results playwright-report",
    "pretest": "npm run clean",
    "test:mcp": "node mcpServer.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@currents/playwright": "^1.16.0",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.55.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "moment": "^2.30.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@playwright/mcp": "^0.0.37",
    "@types/cucumber-html-reporter": "^5.0.4",
    "@types/winston": "^2.4.4",
    "cross-env": "^10.0.0",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^17.2.2",
    "fs-extra": "^11.3.1",
    "playwright-enhanced-reporter": "^1.0.2",
    "playwright-test-generator": "^1.0.3",
    "playwrightfw": "file:",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  }
}
