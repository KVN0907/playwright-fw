# Staging Environment Variables
NODE_ENV=staging
STAGING_BASE_URL=https://saasifier-staging.ey.com/
STAGING_API_URL=https://saasifier-staging.ey.com/api
STAGING_SSO_USERNAME=your-staging-username
STAGING_SSO_PASSWORD=your-staging-password

# Test Configuration
TIMEOUT=45000
RETRIES=2
PARALLEL_THREAD=2
HEADLESS=true
SLOW_MO=0
VIDEO=retain-on-failure
SCREENSHOT=only-on-failure
TRACE=retain-on-failure

# Browser Settings
BROWSER=chromium
