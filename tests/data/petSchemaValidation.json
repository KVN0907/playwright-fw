{
  "petSchemas": {
    "findPetByIdResponse": {
      "endpoint": "/pet/{petId}",
      "method": "GET",
      "responseCode": "200",
      "contentType": "application/json",
      "schemaType": "object",
      "requiredFields": ["id", "category", "name", "photoUrls", "tags", "status"],
      "properties": [
        {
          "name": "id",
          "type": "integer (int64)",
          "description": "Pet ID",
          "required": true,
          "example": "10"
        },
        {
          "name": "category",
          "type": "object",
          "description": "Pet category",
          "required": true,
          "nestedFields": ["id", "name"],
          "example": {
            "id": 1,
            "name": "Dogs"
          }
        },
        {
          "name": "name",
          "type": "string",
          "description": "Pet name",
          "required": true,
          "example": "doggie"
        },
        {
          "name": "photoUrls",
          "type": "array",
          "itemType": "string",
          "description": "Pet photo URLs",
          "required": true,
          "example": ["string"]
        },
        {
          "name": "tags",
          "type": "array",
          "itemType": "object",
          "description": "Pet tags",
          "required": true,
          "nestedFields": ["id", "name"],
          "example": [
            {
              "id": 0,
              "name": "string"
            }
          ]
        },
        {
          "name": "status",
          "type": "string",
          "description": "Pet status in the store",
          "required": true,
          "enumValues": ["available", "pending", "sold"],
          "example": "available"
        }
      ]
    }
  }
}