{
  "schemas": {
    "getUserByIdResponse": {
      "endpoint": "/users/{userId}",
      "method": "GET",
      "responseCode": "200",
      "contentType": "application/json",
      "schemaType": "object",
      "properties": [
        {
          "name": "id",
          "type": "integer (int64)",
          "description": "Unique identifier for the user",
          "required": true,
          "example": "12345"
        },
        {
          "name": "username",
          "type": "string",
          "description": "User's username",
          "required": true,
          "example": "johndoe"
        },
        {
          "name": "email",
          "type": "string (email)",
          "description": "User's email address",
          "required": true,
          "example": "john.doe@example.com"
        },
        {
          "name": "firstName",
          "type": "string",
          "description": "User's first name",
          "required": false,
          "example": "John"
        },
        {
          "name": "lastName",
          "type": "string",
          "description": "User's last name",
          "required": false,
          "example": "Doe"
        },
        {
          "name": "createdAt",
          "type": "string (date-time)",
          "description": "When the user was created",
          "required": true,
          "example": "2023-10-01T12:00:00Z"
        },
        {
          "name": "updatedAt",
          "type": "string (date-time)",
          "description": "When the user was last updated",
          "required": true,
          "example": "2023-10-15T14:30:00Z"
        }
      ]
    },
    "createUserResponse": {
      "endpoint": "/users",
      "method": "POST",
      "responseCode": "201",
      "contentType": "application/json",
      "schemaType": "object",
      "properties": [
        {
          "name": "id",
          "type": "integer (int64)",
          "description": "Unique identifier for the newly created user",
          "required": true,
          "example": "12346"
        },
        {
          "name": "username",
          "type": "string",
          "description": "User's username",
          "required": true,
          "example": "newuser"
        },
        {
          "name": "email",
          "type": "string (email)",
          "description": "User's email address",
          "required": true,
          "example": "newuser@example.com"
        },
        {
          "name": "createdAt",
          "type": "string (date-time)",
          "description": "When the user was created",
          "required": true,
          "example": "2023-10-16T10:00:00Z"
        }
      ]
    }
  }
}