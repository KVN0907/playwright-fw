# Playwright Test Framework - Environment Configuration Template
# Copy this file to create environment-specific configurations in config/environments/
# Example: config/environments/dev.env, config/environments/qa.env

# ====================
# Application URLs
# ====================
APP_URL=https://your-app-url.com
API_URL=https://your-api-url.com

# ====================
# Authentication
# ====================
# SSO Credentials
SSO_USERNAME=your-sso-username@company.com
SSO_PASSWORD=your-sso-password

# Form Login Credentials (if applicable)
FORM_USERNAME=your-username
FORM_PASSWORD=your-password

# ====================
# Test Configuration
# ====================
# Environment name (dev, qa, staging, prod)
NODE_ENV=qa
TEST_ENV=qa

# Test execution settings
HEADLESS=false
WORKERS=4
TIMEOUT=30000
RETRIES=2

# ====================
# Azure DevOps Integration (Optional)
# ====================
ADO_ORGANIZATION=your-organization
ADO_PROJECT=your-project
ADO_PERSONAL_ACCESS_TOKEN=your-pat-token

# ====================
# Reporting & Logging
# ====================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Report output directory
REPORT_DIR=./test-results

# ====================
# Browser Configuration
# ====================
# Browsers to test (chromium, firefox, webkit)
BROWSERS=chromium

# Mobile testing (true/false)
MOBILE_TESTING=false

# ====================
# Advanced Settings
# ====================
# Debug mode
DEBUG=false

# Slow motion (milliseconds between actions)
SLOW_MO=0

# Screenshot on failure (true/false)
SCREENSHOT_ON_FAILURE=true

# Video recording (on, off, retain-on-failure)
VIDEO=retain-on-failure

# Trace recording (on, off, retain-on-failure)
TRACE=retain-on-failure

# ====================
# API Testing
# ====================
# API base URL (if different from APP_URL)
API_BASE_URL=https://api.your-app.com

# API timeout (milliseconds)
API_TIMEOUT=15000

# API retries
API_RETRIES=3

# ====================
# Database (Optional)
# ====================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=testdb
# DB_USER=testuser
# DB_PASSWORD=testpass

# ====================
# Third-party Services (Optional)
# ====================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DATADOG_API_KEY=your-api-key
# NEW_RELIC_LICENSE_KEY=your-license-key

# ====================
# CI/CD Variables (Auto-detected in CI)
# ====================
# CI=true
# GITHUB_ACTIONS=true
# CIRCLE_CI=true
# JENKINS=true
