# Example environment configuration for multiple authentication types

# Environment Setting
NODE_ENV=qa

# Base URL Configuration
APP_URL=https://infinity-qa.ey.com/
QA_APP_URL=https://infinity-qa.ey.com/

# ================================
# AUTHENTICATION CONFIGURATION
# ================================

# Choose one authentication type:
# - browser_session (current method using UI login + cookies)
# - bearer_token (Token-based authentication)
# - jwt_token (JWT token authentication)
# - api_key (API key authentication)
# - basic_auth (Basic HTTP authentication)
# - oauth2 (OAuth2 client credentials flow)
# - custom_headers (Custom header-based authentication)

QA_AUTH_TYPE=browser_session

# ================================
# BROWSER SESSION AUTHENTICATION
# ================================
# Used when AUTH_TYPE=browser_session
QA_USERNAME=superadmin
QA_PASSWORD=superadmin

# ================================
# TOKEN-BASED AUTHENTICATION
# ================================
# Used when AUTH_TYPE=bearer_token or jwt_token

# Option 1: Use existing token
# QA_AUTH_TOKEN=your_existing_token_here

# Option 2: Obtain token via login (requires username/password)
# QA_USERNAME=your_username
# QA_PASSWORD=your_password
# QA_LOGIN_ENDPOINT=/api/auth/login
# QA_TOKEN_FIELD=access_token

# ================================
# API KEY AUTHENTICATION
# ================================
# Used when AUTH_TYPE=api_key
# QA_API_KEY=your_api_key_here

# ================================
# BASIC AUTHENTICATION
# ================================
# Used when AUTH_TYPE=basic_auth
# QA_USERNAME=your_username
# QA_PASSWORD=your_password

# ================================
# OAUTH2 AUTHENTICATION
# ================================
# Used when AUTH_TYPE=oauth2
# QA_CLIENT_ID=your_client_id
# QA_CLIENT_SECRET=your_client_secret
# QA_TOKEN_ENDPOINT=/oauth/token

# ================================
# CUSTOM HEADERS AUTHENTICATION
# ================================
# Used when AUTH_TYPE=custom_headers
# QA_CUSTOM_HEADERS={"X-API-Token":"your_token","X-Client-ID":"your_client_id"}

# ================================
# TOKEN REFRESH CONFIGURATION
# ================================
# Optional: For automatic token refresh
# QA_REFRESH_TOKEN=your_refresh_token
# QA_REFRESH_ENDPOINT=/api/auth/refresh

# ================================
# ENDPOINT CONFIGURATION
# ================================
# Customize authentication endpoints if needed
# QA_LOGIN_ENDPOINT=/api/auth/login
# QA_TOKEN_ENDPOINT=/api/auth/token
# QA_REFRESH_ENDPOINT=/api/auth/refresh

# Storage configuration
# QA_STORAGE_KEY=auth_token
# QA_TOKEN_FIELD=access_token

# ================================
# GENERAL CONFIGURATION
# ================================
# Timeouts
PAGE_TIMEOUT=10000
VERIFY_TIMEOUT=15000

# Authentication Configuration
HAS_LANDING_PAGE=true

# Testing Configuration
HEADLESS=true
RETRIES=1
WORKERS=1
TIMEOUT=30000
TRACE=true
VIDEO=true
SCREENSHOT=true
